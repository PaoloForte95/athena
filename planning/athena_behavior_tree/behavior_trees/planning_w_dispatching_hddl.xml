<root BTCPP_format="4" main_tree_to_execute="MasterTree">

<BehaviorTree ID="MasterTree">
  <Sequence>
  <ComputePlan name="ComputePlanAction" planner="Lilotane" execution_plan="{execution_plan}" domain_file="{domain_file}" problem_file="{problem_file}" plan_length="{plan_length}" robots="{robots}"/>
  <DispatcherNode name="DispatcherNode" execution_plan="{execution_plan}" completed_actions="{completed_actions}" completed_methods="{completed_methods}" type="method">
  <MovePileMethodNode name= "Move Pile" robot_id="robot1">
  <SendMove name="Move" robot_id="robot1" service_name="move_to_pose"/>
  <SendLoad name="Load" robot_id="robot1" service_name="send_load"/>
  <SendMove name="Move" robot_id="robot1" service_name="move_to_pose"/>
  <SendDump name="Dump" robot_id="robot1" service_name="send_dump"/>
  <IsPileMoved name="Check" criteria="Amount" desired_amount="10.0" robot_id="robot1"/>
  </MovePileMethodNode>
  </DispatcherNode>
  </Sequence> 
</BehaviorTree>

</root>
